rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;

      allow create: if request.auth.uid == userId
        && (request.resource.data.role == null || request.resource.data.role in ['student', 'school', 'company'])
        && request.resource.data.isActive == true
        && request.resource.data.isTemporary == false;

      allow update: if isAdmin()
        || (request.auth.uid == userId
          && (request.resource.data.role == resource.data.role || (resource.data.role == null && request.resource.data.role in ['student', 'school', 'company']))
          && request.resource.data.isActive == resource.data.isActive);

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /internships/{internshipId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.companyId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company';
      allow update, delete: if isSignedIn()
        && resource.data.companyId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read, create, update, delete: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn()
        && (resource.data.companyId == request.auth.uid || resource.data.schoolId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.companyId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.companyId == request.auth.uid || resource.data.schoolId == request.auth.uid);
      allow delete: if false;
    }

    match /profiles_public/{profileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /school_students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.schoolId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school';
      allow update, delete: if isSignedIn()
        && resource.data.schoolId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.studentId
          || resource.data.companyId == request.auth.uid
          || (resource.data.internshipId != null && resource.data.internshipId != '' && exists(/databases/$(database)/documents/internships/$(resource.data.internshipId)) && get(/databases/$(database)/documents/internships/$(resource.data.internshipId)).data.companyId == request.auth.uid)
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.studentId
          || (exists(/databases/$(database)/documents/internships/$(resource.data.internshipId)) && get(/databases/$(database)/documents/internships/$(resource.data.internshipId)).data.companyId == request.auth.uid));
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
